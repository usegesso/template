---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/href';

// A "where to buy" hub: outbound links to the shops and galleries that carry the
// artist's work. Settings-driven (no new collection). The page only appears in the
// menu when pages.stockists is on; the list is empty by default.
const settings = (await getEntry('site', 'settings'))!.data;
const artist = settings.logoText || settings.siteTitle;
const stockists = settings.stockists ?? [];
---

<Base
  pageTitle="Where to buy"
  pageDescription={`Where to find work by ${artist}`}
  pageImage={withBase('/og/stockists.png')}
>
  <div class="ez-container ez-stockists">
    <h1>Where to buy</h1>
    {stockists.length === 0 && (
      <p class="ez-stockists__empty">No stockists listed yet — check back soon.</p>
    )}
    {stockists.length > 0 && (
      <ul class="ez-stockists__list" role="list">
        {stockists.map((s) => (
          <li class="ez-stockists__item">
            <a class="ez-stockists__link" href={s.url} rel="noopener" target="_blank">
              <span class="ez-stockists__name">{s.name}</span>
              {s.location && <span class="ez-stockists__location">{s.location}</span>}
              {s.note && <span class="ez-stockists__note">{s.note}</span>}
              <span class="ez-stockists__go" aria-hidden="true">Visit →</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .ez-stockists { max-width: var(--ez-prose-max); }
  .ez-stockists__empty { color: var(--ez-stone); }
  .ez-stockists__list {
    list-style: none;
    margin: var(--ez-space-6) 0 0;
    padding: 0;
    display: grid;
    gap: var(--ez-space-4);
  }
  .ez-stockists__link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: var(--ez-space-1) var(--ez-space-4);
    padding: var(--ez-space-4) var(--ez-space-5);
    background: var(--ez-white);
    border: var(--ez-border-width) solid var(--ez-border);
    box-shadow: var(--ez-shadow);
    text-decoration: none;
    color: var(--ez-ink);
  }
  .ez-stockists__link:hover { color: var(--ez-link); }
  .ez-stockists__name { font-family: var(--ez-font-display); font-weight: 700; font-size: var(--ez-text-lg); }
  .ez-stockists__location { grid-column: 1; color: var(--ez-stone); font-size: var(--ez-text-sm); }
  .ez-stockists__note { grid-column: 1 / -1; color: var(--ez-stone); margin-top: var(--ez-space-1); }
  .ez-stockists__go { grid-row: 1; grid-column: 2; font-family: var(--ez-font-display); font-weight: 700; color: var(--ez-link); white-space: nowrap; }
</style>
