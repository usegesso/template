---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import HostForm from '../components/HostForm.astro';
import { hostConfig } from '../lib/host';

const page = await getEntry('pages', 'contact');
const { Content } = await page!.render();
const data = page!.data;
const settings = (await getEntry('site', 'settings'))!.data;

// On Netlify the form uses native Netlify Forms; on hosts without a forms backend
// (GitHub Pages) it POSTs to a FormSubmit endpoint keyed to the artist's email.
// HostForm handles the form itself; this is only for the FormSubmit note below.
const { useNetlifyForms } = hostConfig();
---

<Base pageTitle={data.title} pageDescription={data.intro}>
  <div class="ez-container ez-contact">
    <h1>{data.title}</h1>
    {data.intro && <p class="ez-contact__intro">{data.intro}</p>}
    <Content />

    {data.email && (
      <p class="ez-contact__mailto">
        Prefer email? Write to <a href={`mailto:${data.email}`}>{data.email}</a>.
      </p>
    )}

    {data.formEnabled && (
      <HostForm name="contact" subject="New message from your portfolio" class="ez-contact__form">
        <div class="ez-field">
          <label class="ez-label" for="name">Name</label>
          <input class="ez-input" type="text" id="name" name="name" required />
        </div>

        <div class="ez-field">
          <label class="ez-label" for="email">Email</label>
          <input class="ez-input" type="email" id="email" name="email" required />
        </div>

        <div class="ez-field">
          <label class="ez-label" for="message">Message</label>
          <textarea class="ez-textarea" id="message" name="message" required></textarea>
        </div>

        <button type="submit" class="ez-btn ez-btn--primary">Send message</button>
      </HostForm>
    )}
    {data.formEnabled && !useNetlifyForms && (
      <p class="ez-contact__formnote">
        Messages are delivered straight to your inbox by FormSubmit, a free form service.
        The first message you receive will ask you to confirm your address once.
      </p>
    )}

    {settings.newsletterEnabled && (
      <NewsletterSignup
        heading={settings.newsletterHeading}
        blurb={settings.newsletterBlurb}
        provider={settings.newsletterProvider}
        actionUrl={settings.newsletterActionUrl}
      />
    )}
  </div>

  {/* When arriving from a piece's "Inquire" button (/contact/?piece=Title), prefill
      the message (and FormSubmit subject) so the artist knows which work it's about.
      No-ops if the form is off or the field is missing. */}
  <script is:inline>
    (function () {
      var piece = new URLSearchParams(location.search).get('piece');
      if (!piece) return;
      var msg = document.getElementById('message');
      if (msg && !msg.value) {
        msg.value = 'I’m interested in “' + piece + '”. ';
        msg.focus();
        msg.setSelectionRange(msg.value.length, msg.value.length);
      }
      var subject = document.querySelector('input[name="_subject"]');
      if (subject) subject.value = 'Inquiry about “' + piece + '”';
    })();
  </script>
</Base>

<style>
  .ez-contact { max-width: var(--ez-prose-narrow-max); }
  .ez-contact__intro {
    font-size: var(--ez-text-lg);
    color: var(--ez-stone);
  }
  .ez-contact__form {
    margin-top: var(--ez-space-6);
    background: var(--ez-white);
    border: var(--ez-border-width) solid var(--ez-border);
    padding: var(--ez-space-6);
  }
  .ez-contact__formnote {
    margin-top: var(--ez-space-3);
    font-size: var(--ez-text-sm);
    color: var(--ez-stone);
  }
</style>
