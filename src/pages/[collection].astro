---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import ArtworkCard from '../components/ArtworkCard.astro';
import Lightbox from '../components/Lightbox.astro';
import { resolveDesign } from '../lib/design';
import { withBase } from '../lib/href';

// Astro 5 content-collection ids include the file extension; strip it for clean
// URLs and for matching artwork series references.
export const getStaticPaths = (async () => {
  const series = await getCollection('collections');
  return series.map((s) => ({
    params: { collection: s.id.replace(/\.md$/, '') },
    props: { series: s },
  }));
}) satisfies GetStaticPaths;

const { series } = Astro.props;
const slugify = (id: string) => id.replace(/\.md$/, '');
const seriesSlug = slugify(series.id);
const settings = (await getEntry('site', 'settings'))!.data;
const design = resolveDesign(settings.design as any);
const linkToPage = design.gallery.click === 'page';

const artworks = (await getCollection('artworks'))
  .filter((a) => a.data.collection && slugify(a.data.collection.id) === seriesSlug)
  .sort((a, b) => a.data.order - b.data.order);

const lightboxItems = await Promise.all(
  artworks.map(async (a) => {
    const img = await getImage({ src: a.data.image, width: 1600 });
    const meta = [a.data.year, a.data.medium, a.data.dimensions].filter(Boolean).join(' · ');
    return { src: img.src, alt: a.data.alt, title: a.data.title, meta };
  })
);
---

<Base pageTitle={series.data.title} pageDescription={series.data.description} pageImage={withBase(`/og/series-${seriesSlug}.png`)}>
  <div class="ez-container">
    <p class="ez-back"><a href={withBase('/')}>← All work</a></p>
    <h1>{series.data.title}</h1>
    {series.data.description && <p class="ez-series-desc">{series.data.description}</p>}

    <div class="ez-portfolio">
      {artworks.map((a, i) => (
        <ArtworkCard
          image={a.data.image}
          title={a.data.title}
          alt={a.data.alt}
          year={a.data.year}
          medium={a.data.medium}
          dimensions={a.data.dimensions}
          price={a.data.price}
          status={a.data.status}
          index={i}
          href={linkToPage ? withBase(`/work/${slugify(a.id)}/`) : undefined}
          hasVideo={!!a.data.video}
          hasAudio={!!a.data.audio}
        />
      ))}
    </div>
  </div>

  {!linkToPage && <Lightbox items={lightboxItems} />}
</Base>

<style>
  .ez-back { margin-bottom: var(--ez-space-4); font-weight: 700; }
  .ez-series-desc {
    color: var(--ez-stone);
    font-size: var(--ez-text-lg);
    max-width: 60ch;
    margin-bottom: var(--ez-space-7);
  }
</style>
