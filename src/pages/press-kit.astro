---
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { CARD_WIDTHS } from '../lib/images';
import { withBase } from '../lib/href';

// A one-page, print-ready press kit artists hand to galleries, grants, and press.
// Reuses the CV's print-to-PDF approach (@media print + window.print()), styled
// with the artist's own --ez-* design tokens so the PDF matches their site. The
// works shown are the ones flagged "featured", so the artist curates the kit from
// the same control that pins pieces to the homepage — no separate list to manage.
const settings = (await getEntry('site', 'settings'))!.data;
const about = await getEntry('pages', 'about');
const contact = await getEntry('pages', 'contact');

const artistName = settings.logoText || settings.siteTitle;
const tagline = settings.tagline;
const email = contact?.data.email;
const socialLinks = settings.socialLinks ?? [];
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const siteHost = siteUrl.host;

const statement = about?.data.statement;
const portrait = about?.data.portrait;
const Bio = about ? (await render(about)).Content : null;

const featured = (await getCollection('artworks'))
  .filter((a) => a.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base pageTitle="Press kit" pageDescription={`Press kit for ${artistName}`} pageImage={withBase('/og/press-kit.png')}>
  <div class="ez-container ez-pk">
    <header class="ez-pk__head">
      <div class="ez-pk__id">
        <h1 class="ez-pk__name">{artistName}</h1>
        <p class="ez-pk__eyebrow">Press kit</p>
        {tagline && <p class="ez-pk__tagline">{tagline}</p>}
      </div>
      <button id="ez-pk-print" class="ez-pk__download" type="button" aria-label="Download this press kit as a PDF">
        Download PDF
      </button>
    </header>

    <ul class="ez-pk__contact" role="list">
      {email && <li><a href={`mailto:${email}`}>{email}</a></li>}
      <li><a href={siteUrl.href} rel="noopener">{siteHost}</a></li>
      {socialLinks.map((s) => (
        <li><a href={s.url} rel="me noopener" target="_blank">{s.label}</a></li>
      ))}
    </ul>

    {(statement || Bio) && (
      <section class="ez-pk__bio">
        <h2 class="ez-pk__heading">About</h2>
        {statement && <p class="ez-pk__statement">{statement}</p>}
        <div class="ez-pk__bioportrait">
          {portrait && <Image src={portrait} alt={artistName} widths={[200, 400]} sizes="160px" class="ez-pk__portrait" />}
          {Bio && <div class="ez-pk__biotext"><Bio /></div>}
        </div>
      </section>
    )}

    {featured.length > 0 && (
      <section class="ez-pk__works">
        <h2 class="ez-pk__heading">Selected work</h2>
        <div class="ez-pk__grid">
          {featured.map((entry) => {
            const a = entry.data;
            const meta = [a.year, a.medium, a.dimensions].filter(Boolean).join(' · ');
            return (
              <figure class="ez-pk__piece">
                <Image src={a.image} alt={a.alt} widths={CARD_WIDTHS} sizes="(max-width: 600px) 50vw, 240px" class="ez-pk__img" />
                <figcaption class="ez-pk__cap">
                  <span class="ez-pk__title">{a.title}</span>
                  {meta && <span class="ez-pk__meta">{meta}</span>}
                </figcaption>
              </figure>
            );
          })}
        </div>
      </section>
    )}

    {featured.length === 0 && (
      <p class="ez-pk__empty">
        Feature a few pieces (the star option when you edit an artwork) and they'll appear
        here, ready to print or save as a PDF.
      </p>
    )}
  </div>

  {/* Print-to-PDF: the browser's "Save as PDF" renders this page with the artist's
      fonts and colours. Mirrors the CV download. */}
  <script is:inline>
    document.getElementById('ez-pk-print')?.addEventListener('click', function () {
      window.print();
    });
  </script>
</Base>

<style>
  .ez-pk { max-width: var(--ez-prose-wide-max); }

  .ez-pk__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--ez-space-5);
    flex-wrap: wrap;
  }
  .ez-pk__name { margin: 0; }
  .ez-pk__eyebrow {
    margin: var(--ez-space-2) 0 0;
    font-family: var(--ez-font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--ez-text-sm);
    color: var(--ez-blue);
  }
  .ez-pk__tagline { margin: var(--ez-space-2) 0 0; color: var(--ez-stone); }

  .ez-pk__download {
    flex-shrink: 0;
    font-family: var(--ez-font-display);
    font-weight: 700;
    font-size: var(--ez-text-sm);
    color: var(--ez-ink);
    background: var(--ez-white);
    border: var(--ez-border-width) solid var(--ez-border);
    border-radius: var(--ez-radius);
    padding: var(--ez-space-2) var(--ez-space-4);
    cursor: pointer;
  }
  .ez-pk__download:hover { color: var(--ez-blue); border-color: var(--ez-blue); }

  .ez-pk__contact {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ez-space-2) var(--ez-space-4);
    list-style: none;
    margin: var(--ez-space-4) 0 var(--ez-space-7);
    padding: 0 0 var(--ez-space-4);
    border-bottom: var(--ez-border-width) solid var(--ez-border);
    font-size: var(--ez-text-sm);
  }
  .ez-pk__contact a { color: var(--ez-ink); }
  .ez-pk__contact a:hover { color: var(--ez-blue); }

  .ez-pk__heading {
    font-size: var(--ez-text-xl);
    border-bottom: var(--ez-border-width) solid var(--ez-border);
    padding-bottom: var(--ez-space-2);
    margin-bottom: var(--ez-space-4);
  }
  .ez-pk__bio { margin-bottom: var(--ez-space-7); }
  .ez-pk__statement { font-size: var(--ez-text-lg); margin: 0 0 var(--ez-space-4); }
  .ez-pk__bioportrait { display: flex; gap: var(--ez-space-5); align-items: flex-start; }
  .ez-pk__portrait {
    width: 160px;
    height: auto;
    flex-shrink: 0;
    border: var(--ez-border-width) solid var(--ez-border);
    background: var(--ez-paper);
  }
  .ez-pk__biotext { line-height: 1.7; }
  .ez-pk__biotext :global(p) { margin: 0 0 var(--ez-space-3); }

  .ez-pk__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--ez-space-5);
  }
  .ez-pk__piece { margin: 0; }
  .ez-pk__img {
    width: 100%;
    height: auto;
    display: block;
    border: var(--ez-border-width) solid var(--ez-border);
    background: var(--ez-paper);
  }
  .ez-pk__cap { display: flex; flex-direction: column; margin-top: var(--ez-space-2); }
  .ez-pk__title { font-family: var(--ez-font-display); font-weight: 700; }
  .ez-pk__meta { color: var(--ez-stone); font-size: var(--ez-text-sm); }
  .ez-pk__empty { color: var(--ez-stone); }

  @media (max-width: 480px) {
    .ez-pk__bioportrait { flex-direction: column; }
    .ez-pk__portrait { width: 120px; }
  }

  /* Print / Save as PDF: drop the site chrome, keep the artist's styled kit, force
     brand colours + borders to render, and avoid splitting a piece across pages. */
  @media print {
    :global(.ez-nav),
    :global(.ez-footer),
    :global(.ez-skip-link) { display: none !important; }
    :global(.ez-main) { padding: 0 !important; }
    .ez-pk__download { display: none !important; }

    @page { margin: 1.6cm; }
    .ez-pk { max-width: none; }
    .ez-pk,
    .ez-pk * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

    .ez-pk__heading { break-after: avoid; }
    .ez-pk__piece { break-inside: avoid; }
  }
</style>
