---
import '../styles/tokens.css';

import { getEntry } from 'astro:content';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import { resolveDesign, designVars, designClasses, motionAttr, googleFontsHref, faviconDataUri, readableOn } from '../lib/design';
import { websiteLd, personLd } from '../lib/structured-data';
import { withBase } from '../lib/href';
import { BUILD_ID } from '../lib/version';

interface Props {
  pageTitle?: string;
  pageDescription?: string;
  pageImage?: string;
  /** Page-specific JSON-LD nodes, merged with the site-level Person + WebSite. */
  jsonLd?: Record<string, unknown>[];
}
const { pageTitle, pageDescription, pageImage, jsonLd = [] } = Astro.props;

// Global settings singleton.
const siteEntry = await getEntry('site', 'settings');
const settings = siteEntry!.data;

// Site-level structured data, emitted on every page. The artist is a Person; the
// site is a WebSite. Pages add their own nodes (VisualArtwork, BreadcrumbList, …).
const siteOrigin = (Astro.site ?? Astro.url).origin;
const artistName = settings.logoText || settings.siteTitle;
const siteJsonLd = [
  websiteLd({
    name: settings.siteTitle,
    url: siteOrigin,
    description: settings.tagline ?? settings.metaDescription,
    author: artistName,
  }),
  personLd({
    name: artistName,
    url: siteOrigin,
    sameAs: settings.socialLinks?.map((s) => s.url),
  }),
  ...jsonLd,
];

// Design tokens drive the whole look. Falls back to Bauhaus defaults.
const design = resolveDesign(settings.design as any);
const rootStyle = designVars(design);
const rootClass = designClasses(design);
const fontsHref = googleFontsHref(design);
// Favicon: the artist's uploaded image, or their initials on the accent color.
const faviconHref =
  design.favicon.mode === 'image' && design.favicon.image
    ? design.favicon.image
    : faviconDataUri(settings.siteTitle, design.color.accent, readableOn(design.color.accent));

// RSS feed for News — only advertised (head + footer) when the News page is on.
const rssHref = design.pages.news ? withBase('/rss.xml') : undefined;

// "Available for work" banner. Off by default; missing settings read as off, so
// existing sites are unchanged on update. The CTA falls back to the Commissions
// page when it's enabled, otherwise Contact. An external URL (http/mailto) is used
// as-is; anything else is treated as an internal path.
const availableForWork = settings.availableForWork === true;
const availableForWorkText = settings.availableForWorkText?.trim() || 'Available for work';
const rawCta = settings.availableForWorkCta?.trim();
const defaultCta = design.pages.commissions ? '/commissions/' : '/contact/';
const ctaTarget = rawCta || defaultCta;
const ctaIsExternal = /^(https?:|mailto:)/i.test(ctaTarget);
const availableForWorkCta = ctaIsExternal ? ctaTarget : withBase(ctaTarget);
---

<!doctype html>
<html lang="en" data-motion={motionAttr(design)} class={rootClass} style={rootStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={faviconHref} />
    <meta name="generator" content={Astro.generator} />
    {settings.protectFromAI && <meta name="robots" content="noai, noimageai" />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsHref} />

    <SEO
      siteTitle={settings.siteTitle}
      metaDescription={settings.metaDescription}
      ogImage={settings.ogImage}
      pageTitle={pageTitle}
      pageDescription={pageDescription}
      pageImage={pageImage}
      jsonLd={siteJsonLd}
    />

    {rssHref && (
      <link rel="alternate" type="application/rss+xml" title={`${settings.siteTitle} — News`} href={rssHref} />
    )}

    {/* Client-side search (Pagefind). The index + UI bundle are generated by the
        build step (pagefind --site dist) and live at /pagefind/. Only loaded when
        the artist turns search on. */}
    {settings.searchEnabled && (
      <link rel="stylesheet" href={withBase('/pagefind/pagefind-ui.css')} />
    )}

    {/* Set motion attribute before paint to avoid a flash, honoring OS + stored pref. */}
    <script is:inline define:vars={{ fallback: settings.motionDefault }}>
      (function () {
        try {
          var os = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var stored = localStorage.getItem('ez-motion');
          var pref = os ? 'reduced' : stored === 'full' || stored === 'reduced' ? stored : fallback;
          document.documentElement.setAttribute('data-motion', pref);
        } catch (e) {}
      })();
    </script>

    <Analytics provider={settings.analyticsProvider} id={settings.analyticsId} host={settings.analyticsHost} />
    {/* Legacy Cloudflare token (predates the provider picker). Routed through the
        same component so the beacon markup lives in one place; skipped when the
        provider is already Cloudflare so the beacon can't double-fire. */}
    {settings.cfAnalyticsToken && settings.analyticsProvider !== 'cloudflare' && (
      <Analytics provider="cloudflare" id={settings.cfAnalyticsToken} />
    )}
    {settings.analyticsSnippet && <Fragment set:html={settings.analyticsSnippet} />}
    {settings.customCss && <style set:html={settings.customCss}></style>}

    {/* Auto-refresh when a newer build has deployed, so an edit shows up without the
        visitor doing a hard refresh (browsers/CDNs cache HTML — GitHub Pages for ~10
        min). We compare this page's build id against /version.json (fetched bypassing
        the cache); on a mismatch, prime the HTTP cache with fresh HTML then reload. A
        per-version sessionStorage guard prevents any reload loop. */}
    <script is:inline define:vars={{ buildId: BUILD_ID, versionUrl: withBase('/version.json') }}>
      (function () {
        if (!buildId) return;
        var busy = false;
        function check() {
          if (busy || document.hidden) return;
          busy = true;
          fetch(versionUrl, { cache: 'no-store' })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (d) {
              if (!d || !d.v || d.v === buildId) return;
              var key = 'ez-reloaded-' + d.v;
              if (sessionStorage.getItem(key)) return;
              sessionStorage.setItem(key, '1');
              fetch(location.href, { cache: 'reload' }).catch(function () {}).then(function () { location.reload(); });
            })
            .catch(function () {})
            .then(function () { busy = false; });
        }
        check();
        document.addEventListener('visibilitychange', function () { if (!document.hidden) check(); });
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="ez-skip-link">Skip to content</a>

    <Nav logoText={settings.logoText} logo={design.logo} search={settings.searchEnabled} />

    {availableForWork && (
      <aside class="ez-available" data-pagefind-ignore aria-label="Availability">
        <span class="ez-available__dot" aria-hidden="true"></span>
        <span class="ez-available__text">{availableForWorkText}</span>
        <a class="ez-available__cta" href={availableForWorkCta} {...(ctaIsExternal ? { rel: 'noopener', target: '_blank' } : {})}>Get in touch</a>
      </aside>
    )}

    <main id="main" class="ez-main" data-pagefind-body>
      <slot />
    </main>

    <Footer
      logoText={settings.logoText}
      socialLinks={settings.socialLinks}
      footerText={design.footer.text}
      rssHref={rssHref}
      supportLinks={settings.supportLinks}
      newsletter={settings.newsletterEnabled && settings.newsletterInFooter
        ? {
            heading: settings.newsletterHeading,
            blurb: settings.newsletterBlurb,
            provider: settings.newsletterProvider,
            actionUrl: settings.newsletterActionUrl,
          }
        : null}
    />

    {settings.rightClickProtect && (
      <script is:inline>
        document.addEventListener('contextmenu', function (e) {
          if (e.target && e.target.closest('img')) e.preventDefault();
        });
      </script>
    )}

    {/* Initialize the Pagefind search box (its assets are built into /pagefind/). */}
    {settings.searchEnabled && (
      <script is:inline define:vars={{ uiUrl: withBase('/pagefind/pagefind-ui.js') }}>
        (function () {
          var el = document.getElementById('ez-search');
          if (!el) return;
          var s = document.createElement('script');
          s.src = uiUrl;
          s.onload = function () {
            if (window.PagefindUI) {
              new window.PagefindUI({ element: '#ez-search', showImages: false, showSubResults: true });
            }
          };
          document.body.appendChild(s);
        })();
      </script>
    )}

    {/* Artist's own custom code (scripts/embeds), runs at the end of the page. */}
    {settings.customCode && <Fragment set:html={settings.customCode} />}
  </body>
</html>

<style>
  .ez-main {
    flex: 1 0 auto;
    min-height: 50vh;
    padding-block: var(--ez-space-7);
  }

  /* Slim site-wide "available for work" banner. Sits between the nav and main,
     styled from design tokens so it inherits the artist's theme (incl. dark). */
  .ez-available {
    display: flex;
    align-items: center;
    gap: var(--ez-space-3);
    flex-wrap: wrap;
    padding: var(--ez-space-3) var(--ez-space-5);
    background: var(--ez-blue);
    color: var(--ez-pill-available-text);
    font-size: 0.95rem;
    border-bottom: var(--ez-border-width) solid var(--ez-border);
  }
  .ez-available__dot {
    width: 0.55em;
    height: 0.55em;
    border-radius: 50%;
    background: currentColor;
    flex: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ez-available__dot {
      animation: ez-available-pulse 2.4s ease-in-out infinite;
    }
  }
  @keyframes ez-available-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .ez-available__text {
    font-weight: 600;
  }
  .ez-available__cta {
    margin-inline-start: auto;
    color: inherit;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .ez-available__cta:hover {
    text-decoration: none;
  }
</style>
