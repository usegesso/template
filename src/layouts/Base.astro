---
import '@fontsource-variable/jost';
import '@fontsource-variable/hanken-grotesk';
import '../styles/tokens.css';

import { getEntry } from 'astro:content';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import { resolveDesign, designVars, designClasses, motionAttr, googleFontsHref, faviconDataUri, readableOn } from '../lib/design';
import { websiteLd, personLd } from '../lib/structured-data';
import { withBase } from '../lib/href';

interface Props {
  pageTitle?: string;
  pageDescription?: string;
  pageImage?: string;
  /** Page-specific JSON-LD nodes, merged with the site-level Person + WebSite. */
  jsonLd?: Record<string, unknown>[];
}
const { pageTitle, pageDescription, pageImage, jsonLd = [] } = Astro.props;

// Global settings singleton.
const siteEntry = await getEntry('site', 'settings');
const settings = siteEntry!.data;

// Site-level structured data, emitted on every page. The artist is a Person; the
// site is a WebSite. Pages add their own nodes (VisualArtwork, BreadcrumbList, …).
const siteOrigin = (Astro.site ?? Astro.url).origin;
const artistName = settings.logoText || settings.siteTitle;
const siteJsonLd = [
  websiteLd({
    name: settings.siteTitle,
    url: siteOrigin,
    description: settings.tagline ?? settings.metaDescription,
    author: artistName,
  }),
  personLd({
    name: artistName,
    url: siteOrigin,
    sameAs: settings.socialLinks?.map((s) => s.url),
  }),
  ...jsonLd,
];

// Design tokens drive the whole look. Falls back to Bauhaus defaults.
const design = resolveDesign(settings.design as any);
const rootStyle = designVars(design);
const rootClass = designClasses(design);
const fontsHref = googleFontsHref(design);
// Favicon: the artist's uploaded image, or their initials on the accent color.
const faviconHref =
  design.favicon.mode === 'image' && design.favicon.image
    ? design.favicon.image
    : faviconDataUri(settings.siteTitle, design.color.accent, readableOn(design.color.accent));

// RSS feed for News — only advertised (head + footer) when the News page is on.
const rssHref = design.pages.news ? withBase('/rss.xml') : undefined;
---

<!doctype html>
<html lang="en" data-motion={motionAttr(design)} class={rootClass} style={rootStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={faviconHref} />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsHref} />

    <SEO
      siteTitle={settings.siteTitle}
      metaDescription={settings.metaDescription}
      ogImage={settings.ogImage}
      pageTitle={pageTitle}
      pageDescription={pageDescription}
      pageImage={pageImage}
      jsonLd={siteJsonLd}
    />

    {rssHref && (
      <link rel="alternate" type="application/rss+xml" title={`${settings.siteTitle} — News`} href={rssHref} />
    )}

    {/* Set motion attribute before paint to avoid a flash, honoring OS + stored pref. */}
    <script is:inline define:vars={{ fallback: settings.motionDefault }}>
      (function () {
        try {
          var os = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var stored = localStorage.getItem('ez-motion');
          var pref = os ? 'reduced' : stored === 'full' || stored === 'reduced' ? stored : fallback;
          document.documentElement.setAttribute('data-motion', pref);
        } catch (e) {}
      })();
    </script>

    {/* Privacy-friendly analytics (Cloudflare Web Analytics) — one token, no cookies. */}
    {settings.cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${settings.cfAnalyticsToken}"}`}
      ></script>
    )}
    {settings.analyticsSnippet && <Fragment set:html={settings.analyticsSnippet} />}
    {settings.customCss && <style set:html={settings.customCss}></style>}
  </head>
  <body>
    <a href="#main" class="ez-skip-link">Skip to content</a>

    <Nav logoText={settings.logoText} logo={design.logo} />

    <main id="main" class="ez-main">
      <slot />
    </main>

    <Footer logoText={settings.logoText} socialLinks={settings.socialLinks} footerText={design.footer.text} rssHref={rssHref} />

    {settings.rightClickProtect && (
      <script is:inline>
        document.addEventListener('contextmenu', function (e) {
          if (e.target && e.target.closest('img')) e.preventDefault();
        });
      </script>
    )}

    {/* Artist's own custom code (scripts/embeds), runs at the end of the page. */}
    {settings.customCode && <Fragment set:html={settings.customCode} />}
  </body>
</html>

<style>
  .ez-main {
    min-height: 50vh;
    padding-block: var(--ez-space-7);
  }
</style>
