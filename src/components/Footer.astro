---
interface Props {
  logoText: string;
  socialLinks?: { label: string; url: string }[];
  footerText?: string;
  /** When set (News page enabled), shows a link to the RSS feed. */
  rssHref?: string;
}
const { logoText, socialLinks = [], footerText, rssHref } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="ez-footer">
  <div class="ez-container ez-footer__inner">
    <div class="ez-footer__brand"><span>{logoText}</span></div>

    {(socialLinks.length > 0 || rssHref) && (
      <ul class="ez-footer__social">
        {socialLinks.map((link) => (
          <li>
            <a href={link.url} rel="me noopener" target="_blank">{link.label}</a>
          </li>
        ))}
        {rssHref && (
          <li>
            <a href={rssHref} rel="alternate">RSS</a>
          </li>
        )}
      </ul>
    )}

    <p class="ez-footer__meta">
      <span>© {year} {logoText}.</span>
      <span class="ez-footer__text">{footerText ?? ''}</span>
      <span class="ez-footer__credit">Made with <a href="https://easel.rosematcha.com" rel="noopener">Easel</a>.</span>
    </p>
  </div>
</footer>

<style>
  .ez-footer {
    border-top: var(--ez-border-width) solid var(--ez-border);
    margin-top: var(--ez-space-9);
    background: var(--ez-white);
  }
  .ez-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--ez-space-5);
    padding-block: var(--ez-space-6);
  }
  .ez-footer__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--ez-space-3);
    font-family: var(--ez-font-display);
    font-weight: 800;
    margin-right: auto;
  }
  .ez-footer__social {
    display: flex;
    gap: var(--ez-space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    font-weight: 700;
  }
  .ez-footer__meta {
    margin: 0;
    color: var(--ez-stone);
    font-size: var(--ez-text-sm);
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ez-footer__text:empty { display: none; }
</style>
